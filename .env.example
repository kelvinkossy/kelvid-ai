# KelVid AI Environment Variables
# Copy this file to .env and fill in your values

# NextAuth (REQUIRED)
AUTH_SECRET="any-random-string-minimum-32-characters-2026"
AUTH_TRUST_HOST="true"

# HuggingFace Inference API (REQUIRED for AI video generation)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN="your-huggingface-token-here"

# Replicate (OPTIONAL - alternative video generation provider)
# Get your token at: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN="your-replicate-token-here"

# DeepSeek (OPTIONAL - for prompt enhancement via DeepSeek API)
# Get your key at: https://platform.deepseek.com/
DEEPSEEK_API_KEY="your-deepseek-api-key"

# Paystack (OPTIONAL - for payments)
PAYSTACK_SECRET_KEY=""
PAYSTACK_PUBLIC_KEY=""

# App URL - change to your deployment URL
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
